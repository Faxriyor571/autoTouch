{
  "manifest_version": 3,
  "name": "AutoTouch UZEX Result Observer",
  "version": "1.0.0",
  "description": "UZEX action natijasidagi server vaqtini lokal AutoTouch dasturiga uzatadi.",
  "host_permissions": [
    "https://spot.uzex.uz/*",
    "http://127.0.0.1:17321/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://spot.uzex.uz/*"],
      "js": ["network-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://spot.uzex.uz/*"],
      "js": ["relay.js"],
      "run_at": "document_start"
    }
  ]
}
